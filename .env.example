# Configuración de correo para el Agente UV
# ============================================================
# Copie este archivo como .env y configure sus credenciales:
#   cp .env.example .env
#
# Para Gmail, necesita crear una "Contraseña de aplicación":
# 1. Ir a https://myaccount.google.com/apppasswords
# 2. Crear una contraseña de aplicación para "Correo"
# 3. Usar esa contraseña de 16 caracteres aquí
#
# Nunca comparta su .env ni lo suba a un repositorio.

GMAIL_USER=tu_correo@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_DESTINO=robinson.armijo@esmax.cl

# Configuración de MeteoChile (Dirección Meteorológica de Chile)
# ============================================================
# Para obtener credenciales:
# 1. Registrarse en https://climatologia.meteochile.gob.cl
# 2. Iniciar sesión y obtener tu token de API
# 3. Usar tu correo como usuario y el token generado
#
# Sin estas credenciales, el agente usa Open-Meteo como respaldo.

METEOCHILE_USER=tu_correo@correo.cl
METEOCHILE_TOKEN=tu_token_api_personal